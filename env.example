# 환경 변수 예시 파일
# 실제 사용 시 .env 파일로 복사하여 사용하세요
# ⚠️  주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ========================================
# 프론트엔드 설정 (Vite)
# ========================================

# API 설정
VITE_API_BASE_URL=https://greenwear-backend-node-production-1583.up.railway.app
VITE_API_TIMEOUT=10000

# 앱 설정
VITE_APP_TITLE=GreenWear
VITE_APP_VERSION=1.0.0

# 개발 모드 설정
VITE_DEV_MODE=true

# 백엔드 API 엔드포인트
VITE_BACKEND_URL=https://greenwear-backend-node-production-1583.up.railway.app
VITE_WS_URL=wss://greenwear-backend-node-production-1583.up.railway.app

# ========================================
# 백엔드 설정 (Node.js/Express)
# ========================================

# 서버 포트
PORT=5000

# 환경 (development, production, test)
NODE_ENV=development

# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database
# Railway 예시: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway

# JWT 인증 (향후 구현)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# IoT 디바이스 API 키 (쉼표로 구분)
IOT_API_KEYS=device_key_1,device_key_2,device_key_3

# CORS 허용 출처 (쉼표로 구분)
ALLOWED_ORIGINS=https://greenwear-demo.vercel.app,http://localhost:5173

# Rate Limiting 설정
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
IOT_RATE_LIMIT_WINDOW_MS=60000
IOT_RATE_LIMIT_MAX_REQUESTS=60

# 로깅 레벨 (error, warn, info, debug)
LOG_LEVEL=info

# ========================================
# 외부 서비스 API 키
# ========================================

# AWS (선택적)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-west-2

# Google Cloud (선택적)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini AI (선택적)
GEMINI_API_KEY=your-gemini-api-key

# ========================================
# 모니터링 & 알림
# ========================================

# Slack Webhook (알림용, 선택적)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Sentry (에러 추적, 선택적)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ========================================
# 개발 도구
# ========================================

# 디버그 모드
DEBUG=false

# 테스트 데이터 생성
SEED_TEST_DATA=false
